594. Longest Harmonious Subsequence


class Solution {
public:
    int findLHS(vector<int>& nums) {
        unordered_map<int,int> freq;
        
        // count frequency
        for(int num : nums){
            freq[num]++;
        }
        
        int longest = 0;
        
        // check pairs (x, x+1)
        for(auto it : freq){
            int key = it.first;
            
            if(freq.count(key + 1)){
                longest = max(longest, freq[key] + freq[key + 1]);
            }
        }
        
        return longest;
    }
};
