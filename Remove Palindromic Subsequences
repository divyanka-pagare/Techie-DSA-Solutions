1332. Remove Palindromic Subsequences





class Solution {
public:
    int removePalindromeSub(string s) {
        // Check if string is palindrome
        int left = 0, right = s.size() - 1;
        
        while (left < right) {
            if (s[left] != s[right]) {
                return 2; // Not palindrome
            }
            left++;
            right--;
        }
        
        return 1; // Palindrome
    }
};
