541. Reverse String II



class Solution {
public:
    string reverseStr(string s, int k) {
        int n = s.length();
        for (int i = 0; i < n; i += 2 * k) {
            int left = i;
            // either k characters or until end of string
            int right = min(i + k - 1, n - 1);

            // reverse characters from left to right
            while (left < right) {
                swap(s[left++], s[right--]);
            }
        }
        return s;
    }
};
